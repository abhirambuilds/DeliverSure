{
  "expo": {
    "name": "DELIVERSUREAPP",
    "slug": "WeatherShieldApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "weathershieldapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.weathershield.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "WeatherShield needs your location to provide real-time weather protection and automated claims.",
        "NSLocationAlwaysUsageDescription": "WeatherShield needs your location to monitor weather conditions even when the app is in the background.",
        "NSCameraUsageDescription": "WeatherShield needs access to your camera for profile pictures and claim evidence.",
        "NSPhotoLibraryUsageDescription": "WeatherShield needs access to your photo library to upload claim evidence."
      }
    },
    "android": {
      "package": "com.weathershield.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow WeatherShield to use your location for automated insurance claims."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow WeatherShield to access your photos to attach evidence to claims.",
          "cameraPermission": "Allow WeatherShield to use your camera for claim evidence."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e7bf6862-6b4c-4e78-86df-317d19bd0138"
      },
      "SUPABASE_URL": "https://rewvcdogpewqhzytenet.supabase.co",
      "SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJld3ZjZG9ncGV3cWh6eXRlbmV0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUxNTE3MjQsImV4cCI6MjA5MDcyNzcyNH0.uFikOFYtR4lHg6zzPGKac48L4IhWwCmUewPUbeOmleI"
    }
  }
}
